# ============================================================
#  .env — Docker environment variables
# ============================================================
# Rename this file .env to use it.
# Warning: SA_PASSWORD value needs to be set before run.

# SQL Server
SA_USERNAME=sa
SA_PASSWORD=USER_PASSWORD
SERVER_NAME=sqlserver
DATABASE_NAME=DataWarehouse
DATASETS_DIR=datasets_folder_path

# Python ingestion
DRIVER_NAME=ODBC Driver 18 for SQL Server

# Airflow
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=ADMIN_PASSWORD
AIRFLOW_ADMIN_EMAIL=ADMIN_EMAIL

AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=DB_PASSWORD
AIRFLOW_DB_NAME=airflow

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=credential_json_path
GCP_PROJECT_ID=PROJECT_ID
BQ_DATASET_BRONZE=bronze
BQ_DATASET_SILVER=silver
BQ_DATASET_GOLD=gold
