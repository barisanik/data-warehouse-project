# Dockerfile.ingestion
# Purpose: Container for get_data.py — fetches DummyJSON API data and loads into bronze tables.

FROM python:3.11-slim

WORKDIR /app

COPY scripts/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY scripts/bronze/get_data.py .
COPY tests/ ./tests/

CMD ["bash", "-c", "python -m pytest tests/test_get_data.py -v && python get_data.py"]