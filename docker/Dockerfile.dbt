# Dockerfile.dbt
# Purpose: Container for dbt — runs Silver and Gold models against SQL Server.

# dbt deps: installs packages (e.g. dbt-utils) defined in packages.yml
# dbt run: builds Silver and Gold models
# dbt test: runs all schema and custom tests

FROM dwh-base:latest

RUN pip install --no-cache-dir dbt-sqlserver==1.9.2

WORKDIR /dbt

COPY dwh_dbt_files/ .

CMD ["/bin/bash", "-c", "dbt deps --profiles-dir /dbt && dbt run --profiles-dir /dbt && dbt test --profiles-dir /dbt"]